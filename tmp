│   ├── telemetry.proto
│   └── tracking.proto
│
├── services/               # <-- Сами микросервисы
│   │
│   ├── api-gateway/        # Сервис 1
│   │   ├── cmd/            # Точка входа (main.go)
│   │   ├── internal/       # Логика (handlers, service, config)
