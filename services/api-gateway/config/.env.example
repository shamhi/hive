ENV=local

SERVER_PORT=8080

REQUEST_TIMEOUT=15s
SHUTDOWN_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

ORDER_ADDR=passthrough:///order:50051
STORE_ADDR=passthrough:///store:50053
BASE_ADDR=passthrough:///base:50054
TRACKING_ADDR=passthrough:///tracking:50055
DISPATCH_ADDR=passthrough:///dispatch:50052
